<%- include('partials/header') %>

<main class="main-content">

  <section class="form-section">
    <h2><i class="fa-solid fa-seedling"></i> Add New Tree</h2>

    <% if (errors.length) { %>
      <div class="alert alert-error">
        <ul>
          <% errors.forEach(e => { %>
            <li><i class="fa-solid fa-circle-exclamation"></i> <%= e %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/add" method="POST" enctype="multipart/form-data" novalidate>

      <div class="form-group">
        <label for="treename">Tree Name <span class="required">*</span></label>
        <input
          type="text"
          id="treename"
          name="treename"
          placeholder="e.g. Oak Tree"
          value="<%= old.treename || '' %>"
          class="<%= errors.some(e => e.includes('Name')) ? 'input-error' : '' %>"
        />
      </div>

      <div class="form-group">
        <label for="description">Description <span class="required">*</span></label>
        <textarea
          id="description"
          name="description"
          rows="3"
          placeholder="Describe the tree..."
          class="<%= errors.some(e => e.includes('Description')) ? 'input-error' : '' %>"
        ><%= old.description || '' %></textarea>
      </div>

      <div class="form-group">
        <label for="image">Image <span class="optional">(optional)</span></label>
        <input type="file" id="image" name="image" accept="image/*" />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-plus"></i> Add Tree
        </button>
      </div>
    </form>
  </section>

  <section class="list-section">
    <div class="list-header">
      <h2><i class="fa-solid fa-leaf"></i> All Trees (<%= trees.length %>)</h2>
      <% if (trees.length > 0) { %>
        <form action="/reset" method="POST" onsubmit="return confirm('Delete ALL trees? This cannot be undone.')">
          <button type="submit" class="btn btn-danger">
            <i class="fa-solid fa-rotate-left"></i> Reset All
          </button>
        </form>
      <% } %>
    </div>

    <% if (trees.length === 0) { %>
      <div class="empty-state">
        <i class="fa-solid fa-tree"></i>
        <p>No trees yet. Add your first tree above!</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table class="tree-table">
          <thead>
            <tr>
              <th class="col-id">ID</th>
              <th class="col-name">Name</th>
              <th class="col-img">Image</th>
              <th class="col-desc">Description</th>
              <th class="col-action">Action</th>
            </tr>
          </thead>
          <tbody>
            <% trees.forEach(tree => { %>
              <tr>
                <td class="col-id">
                  <span class="id-text" title="<%= tree._id %>">
                    <%= tree._id.toString().slice(0, 8) %>…
                  </span>
                </td>
                <td class="col-name"><strong><%= tree.treename %></strong></td>
                <td class="col-img">
                  <% if (tree.image) { %>
                    <img src="<%= tree.image %>" alt="<%= tree.treename %>" class="thumb" />
                  <% } else { %>
                    <div class="no-thumb"><i class="fa-solid fa-tree"></i></div>
                  <% } %>
                </td>
                <td class="col-desc"><%= tree.description %></td>
                <td class="col-action">
                  <a href="/edit/<%= tree._id %>" class="btn-icon btn-edit" title="Edit">
                    <i class="fa-solid fa-pencil"></i>
                  </a>
                  <form action="/delete/<%= tree._id %>" method="POST" class="inline-form"
                        onsubmit="return confirm('Delete \'<%= tree.treename %>\'?')">
                    <button type="submit" class="btn-icon btn-delete" title="Delete">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

</main>

<%- include('partials/footer') %>
