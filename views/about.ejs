<%- include('partials/header') %>

<main class="main-content about-page">
  <section class="about-section">
    <div class="about-avatar">
      <i class="fa-solid fa-user-tie"></i>
    </div>
    <div class="about-content">
      <h1>About Me</h1>
      <p class="about-intro">
        Hi! I'm a passionate developer and nature lover who built <strong>TreeShop</strong> —
        a place to discover and catalog beautiful trees from around the world.
      </p>
      <div class="about-details">
        <div class="detail-item">
          <i class="fa-solid fa-code"></i>
          <div>
            <strong>Tech Stack</strong>
            <span>Node.js · Express · EJS · MongoDB · Docker</span>
          </div>
        </div>
        <div class="detail-item">
          <i class="fa-solid fa-envelope"></i>
          <div>
            <strong>Contact</strong>
            <span>abc@gmail.com</span>
          </div>
        </div>
        <div class="detail-item">
          <i class="fa-solid fa-seedling"></i>
          <div>
            <strong>Mission</strong>
            <span>Bringing nature to your doorstep, one tree at a time.</span>
          </div>
        </div>
      </div>
      <a href="/" class="btn btn-primary">
        <i class="fa-solid fa-store"></i> Visit the Shop
      </a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
